"{\n  \"hero\": {\n    \"title\": \"Accessibility Statement how to work around and all\",\n    \"subtitle\": \"Committed to making ancient wisdom accessible to everyone Aman\",\n    \"backgroundImage\": \"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=1920&h=1080&fit=crop\"\n  },\n  \"commitment\": {\n    \"title\": \"Our Accessibility Commitment\",\n    \"subtitle\": \"Ensuring equal access to ancient wisdom for all learners\",\n    \"content\": \"At Shikshanam, we believe that the profound wisdom of our ancestors should be accessible to everyone, regardless of their abilities or circumstances. We are committed to providing an inclusive learning environment that welcomes and supports all students.\",\n    \"principles\": [\n      {\n        \"id\": \"inclusive\",\n        \"title\": \"Inclusive Design\",\n        \"description\": \"Our platform and content are designed with accessibility in mind from the ground up\"\n      },\n      {\n        \"id\": \"support\",\n        \"title\": \"Comprehensive Support\",\n        \"description\": \"We provide various support services to help students with different needs succeed\"\n      },\n      {\n        \"id\": \"continuous\",\n        \"title\": \"Continuous Improvement\",\n        \"description\": \"We regularly review and improve our accessibility features based on user feedback\"\n      },\n      {\n        \"id\": \"training\",\n        \"title\": \"Staff Training\",\n        \"description\": \"Our team is trained to provide inclusive support and accommodations\"\n      }\n    ]\n  },\n  \"features\": {\n    \"title\": \"Accessibility Features\",\n    \"subtitle\": \"Tools and features that make learning accessible\",\n    \"features\": [\n      {\n        \"id\": \"screen-reader\",\n        \"title\": \"Screen Reader Compatibility\",\n        \"description\": \"Our platform is fully compatible with screen readers and assistive technologies\",\n        \"icon\": \"screen-reader\"\n      },\n      {\n        \"id\": \"keyboard\",\n        \"title\": \"Keyboard Navigation\",\n        \"description\": \"Complete platform functionality accessible via keyboard navigation\",\n        \"icon\": \"keyboard\"\n      },\n      {\n        \"id\": \"captions\",\n        \"title\": \"Video Captions\",\n        \"description\": \"All video content includes accurate captions and transcripts\",\n        \"icon\": \"captions\"\n      },\n      {\n        \"id\": \"text-size\",\n        \"title\": \"Adjustable Text Size\",\n        \"description\": \"Users can adjust text size and contrast for better readability\",\n        \"icon\": \"text-size\"\n      },\n      {\n        \"id\": \"audio\",\n        \"title\": \"Audio Descriptions\",\n        \"description\": \"Visual content includes audio descriptions for visually impaired users\",\n        \"icon\": \"audio\"\n      },\n      {\n        \"id\": \"mobile\",\n        \"title\": \"Mobile Accessibility\",\n        \"description\": \"Full accessibility features available on mobile devices\",\n        \"icon\": \"mobile\"\n      }\n    ]\n  },\n  \"accommodations\": {\n    \"title\": \"Accommodations & Support\",\n    \"subtitle\": \"We provide various accommodations to support your learning journey\",\n    \"accommodations\": [\n      {\n        \"id\": \"extended-time\",\n        \"title\": \"Extended Time\",\n        \"description\": \"Additional time for assignments and assessments when needed\"\n      },\n      {\n        \"id\": \"alternative-format\",\n        \"title\": \"Alternative Formats\",\n        \"description\": \"Content available in multiple formats (audio, large print, etc.)\"\n      },\n      {\n        \"id\": \"assistive-technology\",\n        \"title\": \"Assistive Technology Support\",\n        \"description\": \"Compatibility with various assistive technologies and devices\"\n      },\n      {\n        \"id\": \"personal-support\",\n        \"title\": \"Personal Support\",\n        \"description\": \"Dedicated support staff to help with accessibility needs\"\n      }\n    ]\n  },\n  \"contact\": {\n    \"title\": \"Request Accommodations\",\n    \"subtitle\": \"We're here to help make your learning experience accessible\",\n    \"info\": {\n      \"email\": \"accessibility@shikshanam.com\",\n      \"phone\": \"+91-9876543210\",\n      \"hours\": \"Monday-Friday, 9 AM - 6 PM IST\"\n    },\n    \"message\": \"If you need specific accommodations or have questions about accessibility, please don't hesitate to contact us. We're committed to working with you to ensure you have the best possible learning experience.\"\n  },\n  \"standards\": {\n    \"title\": \"Accessibility Standards\",\n    \"subtitle\": \"We follow international accessibility guidelines\",\n    \"standards\": [\n      {\n        \"id\": \"wcag\",\n        \"title\": \"WCAG 2.1 AA Compliance\",\n        \"description\": \"Our platform meets Web Content Accessibility Guidelines 2.1 AA standards\"\n      },\n      {\n        \"id\": \"section508\",\n        \"title\": \"Section 508 Compliance\",\n        \"description\": \"We comply with Section 508 of the Rehabilitation Act\"\n      },\n      {\n        \"id\": \"ada\",\n        \"title\": \"ADA Compliance\",\n        \"description\": \"Our services comply with the Americans with Disabilities Act\"\n      }\n    ]\n  },\n  \"_metadata\": {\n    \"lastModified\": \"2025-01-03T12:00:00.000Z\",\n    \"version\": \"1.0\",\n    \"source\": \"cms\"\n  }\n}"