# Next.js Environment Configuration
# Copy this file to .env.local for local development

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://your-production-url.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DOMAIN=your-domain.com

# Environment
NODE_ENV=development

# Vercel (automatically set on Vercel deployments)
# VERCEL=1

# Bundle Analysis (set to 'true' to enable)
# ANALYZE=false

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Graphy SSO Configuration
GRAPHY_MERCHANT_ID=your_merchant_id
GRAPHY_API_TOKEN=your_graphy_api_token
GRAPHY_BASE_URL=https://your-graphy-domain.com
GRAPHY_LEARNING_HUB_URL=https://your-graphy-domain.com/t/u/activeCourses
GRAPHY_AUTH_URL=https://your-graphy-domain.com/t/u/authenticate

# Database (if you add a database later)
# DATABASE_URL=your_database_url

# Other API Keys (add as needed)
# API_KEY=your_api_key
