# Next.js Environment Configuration
# Copy this file to .env.local for local development

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://shikshanam-final.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DOMAIN=shikshanam.com

# Environment
NODE_ENV=development

# Vercel (automatically set on Vercel deployments)
# VERCEL=1

# Bundle Analysis (set to 'true' to enable)
# ANALYZE=false

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Graphy SSO Configuration
GRAPHY_MERCHANT_ID=hyperquest
GRAPHY_API_TOKEN=52bae682-186d-44af-a933-c6b6808596c9
GRAPHY_BASE_URL=https://courses.shikshanam.in
GRAPHY_LEARNING_HUB_URL=https://courses.shikshanam.in/t/u/activeCourses
GRAPHY_AUTH_URL=https://courses.shikshanam.in/t/u/authenticate

# Graphy API Configuration
GRAPHY_API_BASE=https://api.ongraphy.com/public/v1

# Strapi Configuration (if using)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_TOKEN=your_strapi_token_here

# Database (if you add a database later)
# DATABASE_URL=your_database_url

# Other API Keys (add as needed)
# API_KEY=your_api_key
